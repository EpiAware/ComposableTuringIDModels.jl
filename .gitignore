# Julia resolved environments — never commit Manifests (they pin to one Julia
# version and break the lts/downgrade CI jobs; commit only Project.toml + compat).
Manifest.toml
**/Manifest.toml

# Coverage / profiling artefacts
*.jl.cov
*.jl.*.cov
*.jl.mem
*.cov
*.mem

# Documenter / DocumenterVitepress build output
/docs/build/
/docs/site/
# Generated API reference pages (written by docs/make.jl from module bindings)
/docs/src/lib/
# VitePress / Node build artefacts
/docs/node_modules/
/docs/src/.vitepress/cache/
/docs/src/.vitepress/dist/
/docs/package-lock.json

# OS cruft
.DS_Store
